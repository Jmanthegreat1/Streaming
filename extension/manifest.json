{
  "manifest_version": 3,
  "name": "Live Subtitle Translator",
  "version": "1.0.0",
  "description": "Translate on-screen subtitles to English (or any language) live while you watch. Built for Kan (כאן) and other web players.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Live Subtitle Translator"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "all_frames": true,
      "run_at": "document_idle",
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ]
}
