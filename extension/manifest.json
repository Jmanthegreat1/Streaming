{
  "manifest_version": 3,
  "name": "Live Subtitle Translator",
  "version": "1.1.0",
  "description": "Translate on-screen subtitles to English live while you watch. On-device (Tesseract) or server OCR.",
  "permissions": ["storage", "activeTab", "offscreen"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Live Subtitle Translator"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN",
      "js": ["inject.js"]
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "all_frames": true,
      "run_at": "document_idle",
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["tesseract/*", "offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
